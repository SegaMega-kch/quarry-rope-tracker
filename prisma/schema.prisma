generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int             @id @default(autoincrement())
  login        String          @unique
  passwordHash String
  role         String
  createdAt    DateTime        @default(now())
  movements    RopeMovement[]
  requests     MechanicRequest[]
  toothMovements ToothMovement[]
  assemblyMovements AssemblyMovement[]
  yaknoMovements YaknoMovement[]
  ppMovements PpMovement[]
}

model RopeType {
  id             Int               @id @default(autoincrement())
  name           String            @unique
  standardLength Int
  defaultDiameter String?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  stocks         RopeStock[]
  movements      RopeMovement[]
  requests       MechanicRequest[]
}

model Location {
  id        Int              @id @default(autoincrement())
  name      String           @unique
  category  String
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  stocks    RopeStock[]
  turntables Turntable[]
  fromMoves RopeMovement[]   @relation("FromLocation")
  toMoves   RopeMovement[]   @relation("ToLocation")
  requestsFrom MechanicRequest[] @relation("RequestFrom")
  requestsTo   MechanicRequest[] @relation("RequestTo")
  toothBins ToothBin[] @relation("ToothBinLocation")
  toothMovesFrom ToothMovement[] @relation("ToothMoveFrom")
  toothMovesTo ToothMovement[] @relation("ToothMoveTo")
  toothMoveExcavators ToothMovement[] @relation("ToothMoveExcavator")
  poweredAssemblies Assembly[] @relation("PoweredAssemblyExcavator")
  yaknoBoxes YaknoBox[] @relation("YaknoBoxExcavator")
  yaknoStates YaknoExcavatorState[] @relation("YaknoStateExcavator")
  yaknoMoveExcavators YaknoMovement[] @relation("YaknoMoveExcavator")
  ppEquipment PpPoint[] @relation("PpPointEquipment")
  ppMovementEquipment PpMovement[] @relation("PpMovementEquipment")
}

model Turntable {
  id                Int         @id @default(autoincrement())
  name              String      @unique
  currentLocationId Int?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  currentLocation   Location?   @relation(fields: [currentLocationId], references: [id])
  stocks            RopeStock[]
}

model RopeStock {
  id             Int        @id @default(autoincrement())
  ropeTypeId     Int
  diameter       String
  length         Int
  quantity       Int
  locationId     Int
  placement      String
  status         String
  turntableId    Int?
  lastChangedAt  DateTime   @default(now())
  lastChangedBy  String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  ropeType       RopeType   @relation(fields: [ropeTypeId], references: [id])
  location       Location   @relation(fields: [locationId], references: [id])
  turntable      Turntable? @relation(fields: [turntableId], references: [id])

  @@index([ropeTypeId, diameter, length, locationId, placement, status, turntableId])
  @@index([status, lastChangedAt])
  @@index([turntableId, status])
}

model RopeMovement {
  id             Int            @id @default(autoincrement())
  createdAt      DateTime       @default(now())
  operationId    String?
  userId         Int
  action         String
  ropeTypeId     Int?
  diameter       String?
  length         Int?
  quantity       Int
  fromLocationId Int?
  toLocationId   Int?
  fromPlacement  String?
  toPlacement    String?
  fromStatus     String?
  toStatus       String?
  fromTurntableId Int?
  toTurntableId   Int?
  comment        String?
  user           User           @relation(fields: [userId], references: [id])
  ropeType       RopeType?      @relation(fields: [ropeTypeId], references: [id])
  fromLocation   Location?      @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation     Location?      @relation("ToLocation", fields: [toLocationId], references: [id])

  @@index([userId, operationId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model MechanicRequest {
  id             Int                    @id @default(autoincrement())
  ropeTypeId     Int
  diameter       String
  length         Int
  quantity       Int
  fromLocationId Int
  toLocationId   Int
  comment        String?
  status         String                 @default("NEW")
  createdById    Int
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  ropeType       RopeType               @relation(fields: [ropeTypeId], references: [id])
  fromLocation   Location               @relation("RequestFrom", fields: [fromLocationId], references: [id])
  toLocation     Location               @relation("RequestTo", fields: [toLocationId], references: [id])
  createdBy      User                   @relation(fields: [createdById], references: [id])

  @@index([status, createdAt])
  @@index([createdAt])
}

model ToothType {
  id        Int             @id @default(autoincrement())
  name      String          @unique
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  stocks    ToothStock[]
  movements ToothMovement[]
}

model ToothBin {
  id                Int             @id @default(autoincrement())
  name              String          @unique
  isActive           Boolean         @default(true)
  currentLocationId Int?
  customLocation    String?
  lastChangedAt     DateTime        @default(now())
  lastChangedBy     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  currentLocation   Location?       @relation("ToothBinLocation", fields: [currentLocationId], references: [id])
  stocks            ToothStock[]
  movements         ToothMovement[]
}

model ToothStock {
  id            Int        @id @default(autoincrement())
  binId         Int
  toothTypeId   Int
  condition     String
  quantity      Int        @default(0)
  lastChangedAt DateTime   @default(now())
  lastChangedBy String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  bin           ToothBin   @relation(fields: [binId], references: [id])
  toothType     ToothType  @relation(fields: [toothTypeId], references: [id])

  @@unique([binId, toothTypeId, condition])
  @@index([toothTypeId, condition])
}

model ToothMovement {
  id             Int        @id @default(autoincrement())
  createdAt      DateTime   @default(now())
  userId         Int
  action         String
  binId          Int
  toothTypeId    Int?
  condition      String?
  quantity       Int?
  fromLocationId Int?
  toLocationId   Int?
  fromLocationText String?
  toLocationText   String?
  excavatorLocationId Int?
  comment        String?
  user           User       @relation(fields: [userId], references: [id])
  bin            ToothBin   @relation(fields: [binId], references: [id])
  toothType      ToothType? @relation(fields: [toothTypeId], references: [id])
  fromLocation   Location?  @relation("ToothMoveFrom", fields: [fromLocationId], references: [id])
  toLocation     Location?  @relation("ToothMoveTo", fields: [toLocationId], references: [id])
  excavatorLocation Location? @relation("ToothMoveExcavator", fields: [excavatorLocationId], references: [id])

  @@index([binId, createdAt])
  @@index([userId, createdAt])
}

model AssemblyHorizon {
  id        Int                @id @default(autoincrement())
  name      String             @unique
  sortOrder Int
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  assemblies Assembly[]
  fromMoves AssemblyMovement[] @relation("AssemblyMoveFromHorizon")
  toMoves   AssemblyMovement[] @relation("AssemblyMoveToHorizon")
  yaknoBoxes YaknoBox[]
  yaknoStates YaknoExcavatorState[]
  yaknoMovesFrom YaknoMovement[] @relation("YaknoMoveFromHorizon")
  yaknoMovesTo YaknoMovement[] @relation("YaknoMoveToHorizon")
}

model Assembly {
  id                  Int                @id @default(autoincrement())
  name                String             @unique
  horizonId           Int?
  status              String             @default("WORKING")
  isPowered           Boolean            @default(false)
  excavatorLocationId Int?
  length              Int?
  comment             String?
  lastChangedAt       DateTime           @default(now())
  lastChangedBy       String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  horizon             AssemblyHorizon?   @relation(fields: [horizonId], references: [id])
  excavatorLocation   Location?          @relation("PoweredAssemblyExcavator", fields: [excavatorLocationId], references: [id])
  movements           AssemblyMovement[]
}

model AssemblyMovement {
  id              Int              @id @default(autoincrement())
  createdAt       DateTime         @default(now())
  userId          Int
  action          String
  assemblyId      Int
  fromHorizonId   Int?
  toHorizonId     Int?
  fromPlaceText   String?
  toPlaceText     String?
  oldLength       Int?
  newLength       Int?
  comment         String?
  user            User             @relation(fields: [userId], references: [id])
  assembly        Assembly         @relation(fields: [assemblyId], references: [id])
  fromHorizon     AssemblyHorizon? @relation("AssemblyMoveFromHorizon", fields: [fromHorizonId], references: [id])
  toHorizon       AssemblyHorizon? @relation("AssemblyMoveToHorizon", fields: [toHorizonId], references: [id])

  @@index([userId, createdAt])
  @@index([assemblyId, createdAt])
}

model YaknoBox {
  id                  Int               @id @default(autoincrement())
  number              String            @unique
  isActive            Boolean           @default(true)
  status              String            @default("ACTIVE")
  comment             String?
  excavatorLocationId Int?
  horizonId           Int?
  isPowered           Boolean           @default(false)
  lastChangedAt       DateTime          @default(now())
  lastChangedBy       String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  excavatorLocation   Location?         @relation("YaknoBoxExcavator", fields: [excavatorLocationId], references: [id])
  horizon             AssemblyHorizon?  @relation(fields: [horizonId], references: [id])
  movements           YaknoMovement[]

  @@index([status, isActive])
  @@index([excavatorLocationId, isPowered])
  @@index([horizonId])
}

model YaknoExcavatorState {
  id                  Int              @id @default(autoincrement())
  excavatorLocationId Int              @unique
  horizonId           Int?
  lastChangedAt       DateTime         @default(now())
  lastChangedBy       String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  excavatorLocation   Location         @relation("YaknoStateExcavator", fields: [excavatorLocationId], references: [id])
  horizon             AssemblyHorizon? @relation(fields: [horizonId], references: [id])
}

model YaknoMovement {
  id                  Int              @id @default(autoincrement())
  createdAt           DateTime         @default(now())
  userId              Int
  action              String
  boxId               Int?
  excavatorLocationId Int?
  fromHorizonId       Int?
  toHorizonId         Int?
  fromText            String?
  toText              String?
  beforeState         String?
  afterState          String?
  comment             String?
  user                User             @relation(fields: [userId], references: [id])
  box                 YaknoBox?        @relation(fields: [boxId], references: [id])
  excavatorLocation   Location?        @relation("YaknoMoveExcavator", fields: [excavatorLocationId], references: [id])
  fromHorizon         AssemblyHorizon? @relation("YaknoMoveFromHorizon", fields: [fromHorizonId], references: [id])
  toHorizon           AssemblyHorizon? @relation("YaknoMoveToHorizon", fields: [toHorizonId], references: [id])

  @@index([userId, createdAt])
  @@index([boxId, createdAt])
}

model PpPoint {
  id                  Int         @id @default(autoincrement())
  name                String      @unique
  isActive            Boolean     @default(true)
  equipmentLocationId Int?
  lastChangedAt       DateTime    @default(now())
  lastChangedBy       String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  equipmentLocation   Location?   @relation("PpPointEquipment", fields: [equipmentLocationId], references: [id])
  sectors             PpSector[]
  movements           PpMovement[]

  @@index([isActive, name])
}

model PpSector {
  id            Int          @id @default(autoincrement())
  ppPointId     Int
  name          String
  quantity      Int          @default(0)
  material      String       @default("OVERBURDEN")
  isActive      Boolean      @default(true)
  lastChangedAt DateTime     @default(now())
  lastChangedBy String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  ppPoint       PpPoint      @relation(fields: [ppPointId], references: [id])
  movements     PpMovement[]

  @@unique([ppPointId, name])
  @@index([ppPointId, isActive])
}

model PpMovement {
  id                  Int       @id @default(autoincrement())
  createdAt           DateTime  @default(now())
  userId              Int
  action              String
  ppPointId           Int
  sectorId            Int?
  equipmentLocationId Int?
  oldQuantity         Int?
  newQuantity         Int?
  fromText            String?
  toText              String?
  comment             String?
  user                User      @relation(fields: [userId], references: [id])
  ppPoint             PpPoint   @relation(fields: [ppPointId], references: [id])
  sector              PpSector? @relation(fields: [sectorId], references: [id])
  equipmentLocation   Location? @relation("PpMovementEquipment", fields: [equipmentLocationId], references: [id])

  @@index([userId, createdAt])
  @@index([ppPointId, createdAt])
}
